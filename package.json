{
  "name": "us-prosecutor-database",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "Vue + Firebase civic dataset for prosecutor accountability research.",
  "keywords": [
    "prosecutors",
    "government",
    "politics",
    "database",
    "united states"
  ],
  "repository": "https://github.com/billimarie/prosecutor-database.git",
  "homepage": "https://billimarie.github.io/prosecutor-database/",
  "author": "Billimarie Lubiano Robinson <work@billimarie.com>",
  "license": "GNU GPLv3",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue",
    "seed:local": "node scripts/seedLocalData.mjs",
    "seed:firestore": "node --env-file=.env scripts/seedFirestore.mjs",
    "seed:firestore:csv": "node --env-file=.env scripts/seedFirestoreFromCsv.mjs",
    "normalize:legacy-csv": "node scripts/normalizeLegacyCsv.mjs"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "d3": "^7.9.0",
    "dotenv": "^17.3.1",
    "firebase": "^11.7.3",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.1.0",
    "papaparse": "^5.5.3",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^10.0.0",
